{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/participant", "dest": "/participant.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/", "dest": "/participant.html" }
  ]
}
